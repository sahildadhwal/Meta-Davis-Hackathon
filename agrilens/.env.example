# ─────────────────────────────────────────────
#  AgriLens AI — Environment Variables
#  Copy this file to backend/.env and fill in your keys
# ─────────────────────────────────────────────

# Gemini Vision AI
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Voice
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ElevenLabs Voice Synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Deepgram Speech-to-Text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Bob's real phone number (for non-demo real calls)
BOB_PHONE_NUMBER=+1XXXXXXXXXX

# Public URL for Twilio webhooks (use ngrok for local dev)
# Run: ngrok http 3001  → paste the https URL here
PUBLIC_URL=https://your-ngrok-url.ngrok.io
